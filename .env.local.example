# Supabase — run `supabase status` to get these values
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54351 # Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable_authentication_key> # Publishable Authentication Key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54352/postgres # Database URL for the Drizzle ORM connection string

# Resend — for sending confirmation emails (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REPLY_TO_EMAIL=<dev_email>

# Anthropic
ANTHROPIC_API_KEY=<anthropic_api_key>

# Inngest — for async AI plan generation (https://www.inngest.com/docs/local-development)
# Local dev: set INNGEST_DEV=1 and use any dummy value for INNGEST_EVENT_KEY
# Production: get real keys from https://app.inngest.com
INNGEST_DEV=1
INNGEST_EVENT_KEY=test

# Admin emails
ADMIN_EMAILS=your-email@example.com

# Test mode to save on AI costs
HYROX_TEST_MODE=true

# ---------------------------------------------------------------------------
# RevenueCat — subscription management for the personalized HYROX plan.
# See src/lib/entitlements.ts and src/app/api/webhooks/revenuecat/route.ts.
# ---------------------------------------------------------------------------

# Shared secret for the RevenueCat → /api/webhooks/revenuecat webhook.
# Pick any random string (NOT an RC-issued API key) — generate with:
#   openssl rand -hex 32
# Paste the SAME value into RC dashboard → Integrations → Webhooks →
# Authorization header, formatted as: Bearer <this-value>
REVENUECAT_WEBHOOK_SECRET=<generate_with_openssl_rand_hex_32>

# Turn on paywall enforcement. When "true", /api/hyrox/plan/generate returns
# 402 for users without an active `hyrox_personalized_plan` entitlement.
# Leave false / unset in dev so personalized onboarding stays unblocked.
HYROX_PAYWALL_ENFORCED=false

# RevenueCat public SDK key — one per platform (iOS / Android / Web).
# Safe to expose via NEXT_PUBLIC_ since it's a client SDK key.
# Not yet wired up (pending client SDK integration).
#   iOS:     appl_xxxxxxxxxxxxxxxxxxxxxxxx
#   Android: goog_xxxxxxxxxxxxxxxxxxxxxxxx
#   Web:     rcb_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_REVENUECAT_API_KEY=<rc_test_api_key>
