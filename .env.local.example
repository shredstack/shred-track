# Supabase — run `supabase status` to get these values
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54351 # Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable_authentication_key> # Publishable Authentication Key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54352/postgres # Database URL for the Drizzle ORM connection string

# Resend — for sending confirmation emails (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REPLY_TO_EMAIL=<dev_email>

# Anthropic
ANTHROPIC_API_KEY=<anthropic_api_key>

# Inngest — for async AI plan generation (https://www.inngest.com/docs/local-development)
# Local dev: set INNGEST_DEV=1 and use any dummy value for INNGEST_EVENT_KEY
# Production: get real keys from https://app.inngest.com
INNGEST_DEV=1
INNGEST_EVENT_KEY=test

# Admin emails
ADMIN_EMAILS=your-email@example.com
